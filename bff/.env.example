PORT=4001

# Upstream backend service this BFF calls (modules/module-a/bff/clients/backendClient.ts)
MODULE_A_BACKEND_URL=http://localhost:5001

# Local dev fallback for the Vault-managed key below. In staging/production this is
# NOT read from here: server.ts calls services/secrets.service.ts at boot, which
# overwrites it from Vault before the BFF accepts traffic. See docs/secrets-management.md.
BACKEND_SERVICE_API_KEY=

# Vault AppRole credentials — leave unset for local dev (no-op fallback to the line above).
VAULT_ADDR=https://vault.internal:8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_SECRET_PATH=secret/data/consumer-a-module-a-bff

LOG_LEVEL=info
